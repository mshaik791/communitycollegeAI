{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --ignore-watch node_modules src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "seed": "ts-node-dev --transpile-only scripts/seed.ts"
  },
  "dependencies": {
    "dotenv": "16.4.5",
    "express": "4.21.1",
    "cors": "2.8.5",
    "@prisma/client": "6.1.0",
    "zod": "3.23.8",
    "morgan": "1.10.0",
    "socket.io": "4.8.1",
    "twilio": "5.4.0",
    "@anthropic-ai/sdk": "^0.39.0"
  },
  "devDependencies": {
    "typescript": "5.6.3",
    "@types/express": "4.17.21",
    "@types/node": "22.10.2",
    "@types/cors": "2.8.17",
    "@types/morgan": "1.9.9",
    "ts-node-dev": "2.0.0",
    "eslint": "8.57.0",
    "@typescript-eslint/parser": "8.12.2",
    "@typescript-eslint/eslint-plugin": "8.12.2",
    "prettier": "3.3.3",
    "prisma": "6.1.0"
  }
}

